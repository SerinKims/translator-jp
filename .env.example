APP_ENV=local
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LITERT_LM_MODEL_NAME=gemma4-e4b
LITERT_LM_MODEL_PATH=C:\Users\USER\.litert-lm\models\gemma4-e4b\model.litertlm
LITERT_LM_TIMEOUT_SECONDS=120
